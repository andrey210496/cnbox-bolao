// Plataforma de Bolões CNBOX — Copa do Mundo (v2)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Unidade (academia/franquia) que divulga o bolão
model Unit {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique // código do link rastreável: /u/<slug>
  active    Boolean  @default(true)

  // Dados do responsável (holder) — preenchidos no auto-cadastro /parceiro
  holderName   String? // responsável pela unidade
  holderPhone  String? // WhatsApp do responsável (login)
  holderCpf    String? // CPF do responsável (para a cobrança de ativação)
  pixKey       String? // chave PIX para receber a comissão
  pixKeyType   String? // CPF | EMAIL | PHONE | EVP
  passwordHash String? // senha do holder para acessar o painel

  entryFee Float @default(50) // valor da ENTRADA no bolão desta unidade (mín. R$50)

  createdAt DateTime @default(now())

  users   User[]
  entries Entry[]
  orders  UnitOrder[]

  @@index([slug])
}

// Cobrança de ATIVAÇÃO da unidade (taxa única paga pelo responsável; 100% da casa).
model UnitOrder {
  id     String @id @default(cuid())
  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id])

  amount Float @default(49.9)

  netValue            Float?
  billingType         String?
  estimatedCreditDate DateTime?

  status          String    @default("PENDING") // PENDING | CONFIRMED | EXPIRED | REFUNDED
  asaasCustomerId String?
  asaasPaymentId  String?   @unique
  checkoutUrl     String?

  createdAt   DateTime  @default(now())
  confirmedAt DateTime?

  @@index([status])
}

// Aluno/apostador
model User {
  id           String   @id @default(cuid())
  fullName     String
  phone        String
  cpf          String   @unique
  pixKey       String // chave PIX para receber o prêmio
  pixKeyType   String   @default("CPF") // CPF | EMAIL | PHONE | EVP
  passwordHash String
  unitId       String?
  unit         Unit?    @relation(fields: [unitId], references: [id])
  createdAt    DateTime @default(now())

  entry       Entry?
  predictions Prediction[]

  @@index([cpf])
}

// Jogo da Copa
model Game {
  id           String    @id @default(cuid())
  homeTeam     String
  homeCode     String // arquivo da bandeira em /public/flags
  awayTeam     String
  awayCode     String
  competition  String    @default("Copa do Mundo FIFA 2026")
  stage        String? // fase (Grupos, Oitavas, etc.)
  notes        String? // contexto opcional p/ o Especialista IA (lesões, fase, etc.)
  kickoffAt    DateTime
  status     String    @default("SCHEDULED") // SCHEDULED | CLOSED | FINISHED | CANCELED
  finalHome  Int?
  finalAway  Int?
  finishedAt DateTime?
  scoredAt   DateTime? // quando os pontos das previsões deste jogo foram calculados
  createdAt  DateTime  @default(now())

  predictions Prediction[]

  @@index([status])
  @@index([kickoffAt])
}

// ENTRADA no bolão — pagamento ÚNICO que dá direito a palpitar em todos os jogos.
// Uma por usuário. As % (prêmio/casa/unidade) incidem sobre este valor.
model Entry {
  id     String  @id @default(cuid())
  userId String  @unique
  user   User    @relation(fields: [userId], references: [id])
  unitId String?
  unit   Unit?   @relation(fields: [unitId], references: [id])

  amount            Float // valor pago (entrada da unidade)
  prizeContribution Float // parte que vai pro prêmio da unidade
  houseCut          Float // parte da casa
  unitCommission    Float @default(0) // comissão da unidade (sai da casa)

  // Snapshot financeiro do Asaas (capturado na confirmação)
  netValue            Float?
  billingType         String? // PIX | CREDIT_CARD | DEBIT_CARD
  estimatedCreditDate DateTime?

  status          String    @default("PENDING") // PENDING | CONFIRMED | EXPIRED | FAILED | REFUNDED
  asaasCustomerId String?
  asaasPaymentId  String?   @unique
  checkoutUrl     String?
  pixPayload      String?
  pixQrImage      String?
  pixExpiration   DateTime?

  createdAt   DateTime  @default(now())
  confirmedAt DateTime?

  @@index([unitId, status])
}

// PALPITE — grátis (após pagar a entrada), um por jogo, editável até o início.
model Prediction {
  id     String  @id @default(cuid())
  userId String
  user   User    @relation(fields: [userId], references: [id])
  gameId String
  game   Game    @relation(fields: [gameId], references: [id])
  unitId String? // copiado do usuário, para o ranking por unidade

  homeScore Int
  awayScore Int

  points   Int       @default(0) // calculado após o jogo (exato 5 / vencedor 2 / saldo 1)
  scoredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, gameId])
  @@index([gameId])
  @@index([unitId])
}

// Repasse PIX ao ganhador da liga da unidade (no fim da Copa). Uma por ganhador.
model Payout {
  id              String    @id @default(cuid())
  userId          String    @unique
  unitId          String?
  pixKey          String
  amount          Float
  points          Int       @default(0) // pontuação do ganhador no fechamento
  status          String    @default("PENDING") // PENDING | APPROVED | PROCESSING | SENT | FAILED
  asaasTransferId String?   @unique
  failReason      String?
  createdAt       DateTime  @default(now())
  sentAt          DateTime?

  @@index([unitId, status])
}

// Compra do "Especialista CNBOX" (IA paga, 100% da casa) — acesso por jogo
model SpecialistOrder {
  id     String @id @default(cuid())
  userId String
  gameId String

  amount Float @default(3)

  // Snapshot financeiro do Asaas (capturado na confirmação)
  netValue            Float?
  billingType         String?
  estimatedCreditDate DateTime?

  status          String    @default("PENDING") // PENDING | CONFIRMED | EXPIRED | FAILED | REFUNDED
  asaasCustomerId String?
  asaasPaymentId  String?   @unique
  checkoutUrl     String? // página de pagamento do Asaas (PIX, débito, crédito à vista)
  pixPayload      String?
  pixQrImage      String?
  pixExpiration   DateTime?

  createdAt   DateTime  @default(now())
  confirmedAt DateTime?
  usedAt      DateTime? // quando a dica foi consumida (uso único)

  @@index([userId, gameId])
  @@index([status])
}

// Cache da análise da IA por jogo (gera uma vez, reaproveita)
model GameAnalysis {
  id        String   @id @default(cuid())
  gameId    String   @unique
  content   String // texto da análise
  model     String?
  createdAt DateTime @default(now())
}

// Configurações editáveis (economia do bolão, etc.)
model Setting {
  key   String @id
  value String
}

// Log de auditoria (ações sensíveis: admin, repasses)
model AuditLog {
  id        String   @id @default(cuid())
  action    String
  actor     String // "admin" | userId | "system"
  detail    String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
